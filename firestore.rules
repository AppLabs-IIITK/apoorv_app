rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function requestEmail() {
      return (isSignedIn() && request.auth.token.email is string)
          ? request.auth.token.email
          : '';
    }

    function configData() {
      return get(/databases/$(database)/documents/app_config/global).data;
    }

    function adminEmails() {
      let data = configData();
      return data.adminEmails is list ? data.adminEmails : [];
    }

    function subAdminEmails() {
      let data = configData();
      return data.subAdminEmails is list ? data.subAdminEmails : [];
    }

    function isAdmin() {
      let email = requestEmail();
      return email != '' && email in adminEmails();
    }

    function isSubAdmin() {
      let email = requestEmail();
      return email != '' && email in subAdminEmails();
    }

    function canManageContent() {
      return isAdmin() || isSubAdmin();
    }

    match /users/{userId} {
      allow read: if true;
      allow create: if false;

      function allowedUserUpdate() {
        return request.resource.data.diff(resource.data).changedKeys().hasOnly([
          'name',
          'nameLower',
          'phone',
          'photoURL'
        ]);
      }

      function allowedShopkeeperAdminUpdate() {
        return request.resource.data.diff(resource.data).changedKeys().hasOnly([
            'isShopkeeper',
            'shopPoints'
          ]) &&
          request.resource.data.isShopkeeper is bool &&
          request.resource.data.shopPoints is int &&
          request.resource.data.shopPoints >= 0;
      }

      allow update: if (isOwner(userId) && allowedUserUpdate()) ||
        (canManageContent() && allowedShopkeeperAdminUpdate());

      allow delete: if false;
    }

    match /app_config/{document} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /locations/{locationId} {
      allow read: if isSignedIn();
      allow write: if canManageContent();
    }

    match /events/{eventId} {
      allow read: if isSignedIn();
      allow write: if canManageContent();
    }

    match /feed/{docId} {
      allow read: if isSignedIn();
      allow write: if canManageContent();
    }

    match /{document=**} {
      allow read: if true;
      allow write: if false;
    }
  }
}
