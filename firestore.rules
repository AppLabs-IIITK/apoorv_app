rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ────────────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /// Checks whether the signed-in user's email is in app_config/global.adminEmails.
    /// Uses a single document get() — counts as 1 read against your quota.
    function isAdmin() {
      return isSignedIn() &&
        request.auth.token.email in
          get(/databases/$(database)/documents/app_config/global).data.adminEmails;
    }

    // ── Users ──────────────────────────────────────────────────────────────

    // Anyone can read; only the user can update their own profile fields.
    match /users/{userId} {
      allow read: if true;

      // Created by Cloud Functions (admin SDK). Disallow direct client create.
      allow create: if false;

      function allowedUserUpdate() {
        // Only allow editing onboarding/profile fields.
        // Everything else must remain unchanged.
        return request.resource.data.diff(resource.data).changedKeys().hasOnly([
          'name',
          'nameLower',
          'phone',
          'photoURL'
        ]);
      }

      allow update: if isOwner(userId) && allowedUserUpdate();

      allow delete: if false;
    }

    // ── App Config ─────────────────────────────────────────────────────────

    // Readable by any signed-in user (needed to resolve admin roles on-device).
    // Written only by Firebase Console / Admin SDK — never from the client.
    match /app_config/{document} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // ── Map — Locations ────────────────────────────────────────────────────

    // Any authenticated user can read map markers.
    // Only admins (adminEmails array in app_config/global) can write.
    match /locations/{locationId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ── Map — Events ───────────────────────────────────────────────────────

    // Any authenticated user can read events.
    // Only admins can create, update, or delete events.
    match /events/{eventId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ── Fallback ───────────────────────────────────────────────────────────

    // Everything else: public read, no client writes.
    match /{document=**} {
      allow read: if true;
      allow write: if false;
    }
  }
}
